# Generated by the example Angee staging template.
# Normal users should run `angee up`; this file is the Compose backend output.

name: {{ project_name }}

x-app-env: &app-env
  DJANGO_SETTINGS_MODULE: {{ django_settings }}
  PYTHONPATH: /app/src
  UV_PROJECT_ENVIRONMENT: /opt/.venv
  POSTGRES_HOST: postgres
  DATABASE_URL: postgresql://postgres:${DB_PASSWORD:-postgres}@postgres:5432/${POSTGRES_DB:-fyltr}
  REDIS_URL: redis://redis:6379/0
  CELERY_BROKER_URL: redis://redis:6379/0

services:
  operator:
    image: ghcr.io/fyltr/angee-operator:latest
    restart: unless-stopped
    ports:
      - "${ANGEE_OPERATOR_PORT:-9000}:9000"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - ./{{ ANGEE_ROOT }}:/angee-root
      - .:/stack
    environment:
      ANGEE_ROOT: /angee-root
      ANGEE_MANIFEST: /angee-root/angee.yaml
      ANGEE_STATE_SOURCES: {{ operator_state_sources }}
      ANGEE_DJANGO_URL: {{ django_url }}
      ANGEE_DATABASE_URL: ${ANGEE_DATABASE_URL:-}
    depends_on: [django]
    networks: [angee-net]

  postgres:
    image: pgvector/pgvector:pg17
    command: postgres -c shared_preload_libraries=pg_stat_statements -c pg_stat_statements.track=all -c max_connections=200
    restart: unless-stopped
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: ${DB_PASSWORD:-postgres}
      POSTGRES_DB: ${POSTGRES_DB:-fyltr}
      LETTA_DB_USER: ${LETTA_DB_USER:-letta}
      LETTA_DB_PASSWORD: ${LETTA_DB_PASSWORD:-letta}
    volumes:
      - {{ ANGEE_ROOT }}/data/postgres:/var/lib/postgresql/data
      - ./docker/postgres/ensure-letta-db.sh:/docker-entrypoint-initdb.d/20-ensure-letta-db.sh:ro
    networks: [angee-net]

  redis:
    image: redis:7-alpine
    command: redis-server --appendonly yes --appendfsync everysec --maxmemory 256mb --maxmemory-policy allkeys-lru
    restart: unless-stopped
    volumes:
      - {{ ANGEE_ROOT }}/data/redis:/data
    networks: [angee-net]

  mailhog:
    image: mailhog/mailhog:latest
    restart: unless-stopped
    ports:
      - "1025:1025"
      - "8025:8025"
    networks: [angee-net]

  letta_server:
    image: ghcr.io/fyltr/letta:latest
    hostname: letta
    restart: unless-stopped
    ports:
      - "8083:8083"
      - "8283:8283"
    env_file:
      - .env.letta
    depends_on: [postgres]
    networks: [angee-net]

  livekit:
    image: livekit/livekit-server:latest
    hostname: livekit
    command: --dev --bind 0.0.0.0 --node-ip 0.0.0.0
    restart: unless-stopped
    ports:
      - "7880:7880"
      - "7881:7881"
      - "7882:7882/udp"
    environment:
      LIVEKIT_KEYS: "${LIVEKIT_API_KEY:-devkey}: ${LIVEKIT_API_SECRET:-secret}"
    networks: [angee-net, traefik]
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ project_name }}-livekit.rule=Host(`{{ livekit_domain }}`)"
      - "traefik.http.routers.{{ project_name }}-livekit.entrypoints=web-secure"
      - "traefik.http.routers.{{ project_name }}-livekit.tls=true"
      - "traefik.http.services.{{ project_name }}-livekit.loadbalancer.server.port=7880"
      - "traefik.docker.network=traefik"

  speaches:
    image: ghcr.io/speaches-ai/speaches:latest-cpu
    hostname: speaches
    restart: unless-stopped
    ports:
      - "8880:8000"
    volumes:
      - {{ ANGEE_ROOT }}/data/hf-cache:/home/ubuntu/.cache/huggingface/hub
    networks: [angee-net]

  django:
    build: .
    command: uv run uvicorn config.asgi:application --host 0.0.0.0 --port 8000 --reload
    restart: unless-stopped
    ports:
      - "${DJANGO_PORT:-8000}:8000"
    volumes:
      - .:/app
      - {{ ANGEE_ROOT }}/data/media:/app/media
      - {{ ANGEE_ROOT }}/data/staticfiles:/app/staticfiles
    env_file: .env
    environment:
      <<: *app-env
      DJANGO_DEBUG: "true"
      DJANGO_SECRET_KEY: ${DJANGO_SECRET_KEY:-unsafe-dev-key}
      DJANGO_SQIDS_SALT: ${DJANGO_SQIDS_SALT:-unsafe-dev-salt}
      EMAIL_HOST: mailhog
      EMAIL_PORT: "1025"
      LIVEKIT_URL: ws://livekit:7880
      LIVEKIT_EXTERNAL_URL: wss://{{ livekit_domain }}
    depends_on: [postgres, redis, mailhog, letta_server]
    networks: [angee-net, traefik]
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ project_name }}-django.rule=Host(`{{ domain }}`) && PathPrefix(`/api`, `/ws`, `/admin`, `/media`)"
      - "traefik.http.routers.{{ project_name }}-django.entrypoints=web-secure"
      - "traefik.http.routers.{{ project_name }}-django.tls=true"
      - "traefik.http.services.{{ project_name }}-django.loadbalancer.server.port=8000"
      - "traefik.docker.network=traefik"

  frontend:
    image: node:22-alpine
    command: sh -c "npm install && npm run dev -- --host"
    restart: unless-stopped
    working_dir: /app
    ports:
      - "${FRONTEND_PORT:-3000}:3000"
    volumes:
      - ./frontend:/app
      - /app/node_modules
    environment:
      VITE_PROXY_TARGET: http://django:8000
      VITE_LETTA_TARGET: http://letta:8283
      VITE_ALLOWED_HOST: {{ domain }}
    depends_on: [django]
    networks: [angee-net, traefik]
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ project_name }}-frontend.rule=Host(`{{ domain }}`)"
      - "traefik.http.routers.{{ project_name }}-frontend.entrypoints=web-secure"
      - "traefik.http.routers.{{ project_name }}-frontend.tls=true"
      - "traefik.http.services.{{ project_name }}-frontend.loadbalancer.server.port=3000"
      - "traefik.docker.network=traefik"

  celery:
    build: .
    command: uv run celery -A config.celery_app worker --without-gossip --without-mingle -l info
    restart: unless-stopped
    volumes:
      - .:/app
    env_file: .env
    environment:
      <<: *app-env
    depends_on: [postgres, redis]
    networks: [angee-net]

  celery-whatsapp:
    build: .
    command: uv run celery -A config.celery_app worker --without-gossip --without-mingle -Q whatsapp -c 1 -P solo -l info
    restart: unless-stopped
    volumes:
      - .:/app
    env_file: .env
    environment:
      <<: *app-env
    depends_on: [postgres, redis]
    networks: [angee-net]

  celery-agents:
    build: .
    command: uv run celery -A config.celery_app worker --without-gossip --without-mingle -Q agents -c 2 -l info
    restart: unless-stopped
    volumes:
      - .:/app
    env_file: .env
    environment:
      <<: *app-env
    depends_on: [postgres, redis]
    networks: [angee-net]

  celery-beat:
    build: .
    command: uv run celery -A config.celery_app beat -l info --scheduler django_celery_beat.schedulers:DatabaseScheduler
    restart: unless-stopped
    volumes:
      - .:/app
    env_file: .env
    environment:
      <<: *app-env
    depends_on: [postgres, redis]
    networks: [angee-net]

networks:
  angee-net:
    driver: bridge
  traefik:
    external: true
